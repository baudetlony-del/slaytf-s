<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini Jeux</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            background: #1e1e2f;
            color: white;
            text-align: center;
            margin: 0;
            padding: 20px;
        }

        h1 {
            color: #00d4ff;
        }

        .container {
            max-width: 500px;
            margin: auto;
            background: #2d2d44;
            padding: 20px;
            border-radius: 15px;
        }

        input {
            padding: 10px;
            width: 100px;
            text-align: center;
            font-size: 18px;
        }

        button {
            padding: 10px 15px;
            background: #00d4ff;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
            margin-top: 10px;
        }

        button:hover {
            background: #00aacc;
        }

        #message {
            margin-top: 15px;
            font-size: 18px;
        }
    </style>
</head>
<body>

    <h1>🎮 Mes Mini Jeux</h1>

    <div class="container">
        <h2>Devine le nombre</h2>
        <p>Choisis un nombre entre 1 et 100</p>

        <input type="number" id="guess">
        <br>
        <button onclick="checkGuess()">Tester</button>

        <p id="message"></p>
    </div>

    <script>
        let secretNumber = Math.floor(Math.random() * 100) + 1;
        let attempts = 0;

        function checkGuess() {
            const guess = Number(document.getElementById("guess").value);
            const message = document.getElementById("message");

            attempts++;

            if (guess === secretNumber) {
                message.innerHTML =
                    "🎉 Bravo ! Trouvé en " + attempts + " essais.";

                secretNumber = Math.floor(Math.random() * 100) + 1;
                attempts = 0;
            }
            else if (guess < secretNumber) {
                message.innerHTML = "📈 Plus grand !";
            }
            else {
                message.innerHTML = "📉 Plus petit !";
            }
        }
    </script>

</body>
</html>
